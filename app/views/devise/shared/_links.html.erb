<div class="space-y-2">
  <% if controller_name != "sessions" %>
    <%= link_to "Sign in", new_session_path(resource_name), class: "text-indigo-600 hover:underline" %>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != "registrations" %>
    <div>
      <%= link_to "Create an account", new_registration_path(resource_name), class: "text-indigo-600 hover:underline" %>
    </div>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != "passwords" %>
    <div>
      <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-indigo-600 hover:underline" %>
    </div>
  <% end %>
</div>
